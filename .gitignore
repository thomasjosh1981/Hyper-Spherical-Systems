*.pyc
*.pyo
*.pyd
*.obj
*.spec

# Allow Releases, Installers, Docs, and Guides
!HypeS_Setup.exe
!README.md
!blueprint.json
!config.yaml
!docs/
!docs/**

# OS & Environment
.DS_Store
Thumbs.db
.env
venv/
env/

